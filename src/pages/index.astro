---
import BaseLayout from '../layouts/BaseLayout.vue';
import IndexContent from '../components/IndexContent.vue';
---

<BaseLayout
  title="SDSP | Toronto Post-punk Band"
  description="SDSP (aka. Side Project) are a Toronto post-punk indie band serving up riffs."
>
  <IndexContent />

  <Fragment slot="extra-scripts">
    <script is:inline src="/assets/js/shows.js"></script>
    <script is:inline src="//s3.amazonaws.com/downloads.mailchimp.com/js/mc-validate.js"></script>
    <script is:inline>
      (function ($) {
        window.fnames = new Array();
        window.ftypes = new Array();
        fnames[0] = 'EMAIL';
        ftypes[0] = 'email';
        fnames[1] = 'FNAME';
        ftypes[1] = 'text';
        fnames[2] = 'LNAME';
        ftypes[2] = 'text';
        fnames[3] = 'ADDRESS';
        ftypes[3] = 'address';
        fnames[4] = 'PHONE';
        ftypes[4] = 'phone';
        fnames[5] = 'BIRTHDAY';
        ftypes[5] = 'birthday';
        fnames[6] = 'COMPANY';
        ftypes[6] = 'text';
      }(jQuery));
      var $mcj = jQuery.noConflict(true);
    </script>
  </Fragment>
</BaseLayout>
